{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  // simulation.ts is a Node-only analysis script (run via jiti); it uses node
  // globals (process/fs) absent from the browser app's type environment.
  "exclude": ["src/**/__tests__/*", "src/game/simulation.ts"],
  "compilerOptions": {
    // The ported game engine (src/game/*) is built on dynamic dictionary access
    // keyed by runtime card/building strings (hands, cost tables, lookup maps).
    // noUncheckedIndexedAccess would force pervasive `?? 0` / `!` noise across the
    // tuned logic, so it is left off for this codebase.
    "noUncheckedIndexedAccess": false,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
